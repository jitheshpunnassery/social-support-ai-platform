# --- App ---
API_BASE_URL=http://localhost:8000
AUTO_APPROVE_THRESHOLD=0.80
AUTO_DECLINE_THRESHOLD=0.35

# --- Phase 7: PostgreSQL / MongoDB ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=social_support
POSTGRES_USER=ssuser
POSTGRES_PASSWORD=sspass
MONGO_URI=mongodb://localhost:27017
MONGO_DB=social_support_docs

# --- Phase 8: Local LLM (Ollama, OpenAI-compatible) + Qdrant ---
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=llama3.1:8b-instruct-q4_K_M
OLLAMA_VISION_MODEL=llava:13b
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=policy_precedents

# --- Phase 10: Neo4j graph store + Langfuse observability ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jpass
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000
