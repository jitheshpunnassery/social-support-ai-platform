# --- Relational DB (PostgreSQL) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=social_support
POSTGRES_USER=ssuser
POSTGRES_PASSWORD=sspass
# If PostgreSQL is unreachable, the app auto-falls-back to a local SQLite file (./local.db)
# so the prototype still runs on a laptop with no services installed.

# --- Document store (MongoDB) ---
MONGO_URI=mongodb://localhost:27017
MONGO_DB=social_support_docs

# --- Vector DB (Qdrant) ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=policy_precedents

# --- Graph DB (Neo4j) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jpass

# --- Local LLM (Ollama, OpenAI-compatible endpoint) ---
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=llama3.1:8b-instruct-q4_K_M
OLLAMA_VISION_MODEL=llava:13b

# --- Observability (Langfuse) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# --- App ---
API_BASE_URL=http://localhost:8000
AUTO_APPROVE_THRESHOLD=0.80
AUTO_DECLINE_THRESHOLD=0.35
